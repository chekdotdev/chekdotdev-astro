---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Acknowledgements | Joseph Chekanoff" description="Credits for typefaces, icons, and tools used on josephchekanoff.com.">
  <h1>Acknowledgements</h1>

  <p>This site depends on open source contributions from many hard-working people.</p>

  <section aria-labelledby="icons">
    <h2 id="icons">Icons</h2>
    <p>The home icon is <a href="https://heroicons.com/">Heroicons</a> <code>home-modern</code>.</p>
  </section>

  <section aria-labelledby="typefaces">
    <h2 id="typefaces">Typefaces</h2>
    <p>Body text uses <a href="https://github.com/tonsky/FiraCode">Fira Code</a>.</p>
    <p>Headings use <a href="https://fonts.google.com/specimen/Vollkorn">Vollkorn</a>.</p>
  </section>

  <section aria-labelledby="software">
    <h2 id="software">Software</h2>
    <p>The site is built with <a href="https://astro.build/">Astro</a> and content is sourced from <a href="https://www.wpgraphql.com/">WPGraphQL</a>.</p>
  </section>
</BaseLayout>
