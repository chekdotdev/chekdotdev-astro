---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found | Joseph Chekanoff" description="The page you were looking for could not be found.">
  <section class="not-found" aria-labelledby="not-found-title">
    <p class="not-found-kicker">404</p>
    <h1 id="not-found-title">This page moved out.</h1>
    <p>Nothing exists at this URL. Try the homepage or browse the post archive.</p>
    <p class="not-found-links"><a href="/">Go home</a> <span aria-hidden="true">/</span> <a href="/posts/">Browse posts</a></p>
  </section>
</BaseLayout>
